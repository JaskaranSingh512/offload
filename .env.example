# Copy to .env.local (gitignored) and restart the dev server.
# This app is Next.js — it reads the NEXT_PUBLIC_* names below (the old VITE_* names are unused).

# Supabase (public — browser-safe; required for the GitHub login on /login).
# These two values are the real publishable credentials (they ship in the client bundle
# by design, so they're fine to share). /login needs ONLY these two.
NEXT_PUBLIC_APP_URL=https://offload-sable.vercel.app
NEXT_PUBLIC_SUPABASE_URL=https://rgkchbibpkduwnelpchh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_-23bRn-qlIIudV_dLoa2Nw_WZm9NBmw

# Supabase secret / service-role key — server-only, never expose to browser.
# Get the real value from supabase.com → Settings → API (sb_secret_… or the service_role JWT).
SUPABASE_SECRET_KEY=sb_secret_or_service_role_jwt_here

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Canva Connect API — developers.canva.com/apps → New integration
# Scopes needed: design:content:write design:content:read design:meta:read asset:read
# Auth type: Authorization Code + PKCE (per-user OAuth)
CANVA_CLIENT_ID=...
CANVA_CLIENT_SECRET=...
# Full URL to your deployed callback endpoint — must match what's registered in Canva developer portal
# e.g. https://your-app.vercel.app/api/canva-callback
CANVA_REDIRECT_URI=...
