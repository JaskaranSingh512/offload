# Copy to .env.local (never commit .env.local)

# Supabase — get from supabase.com → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-only, never expose to browser

# For the frontend Vite app (safe to expose)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Canva Connect API — developers.canva.com
CANVA_CLIENT_ID=...
CANVA_CLIENT_SECRET=...
