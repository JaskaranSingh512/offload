# Copy to .env.local (gitignored) and restart the dev server.
# This app is Next.js — it reads the NEXT_PUBLIC_* names below (the old VITE_* names are unused).

# Supabase (public — browser-safe; required for the GitHub login on /login).
# These two values are the real publishable credentials (they ship in the client bundle
# by design, so they're fine to share). /login needs ONLY these two.
NEXT_PUBLIC_APP_URL=https://offload-sable.vercel.app
NEXT_PUBLIC_SUPABASE_URL=https://rgkchbibpkduwnelpchh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_-23bRn-qlIIudV_dLoa2Nw_WZm9NBmw

# Supabase secret / service-role key — server-only, never expose to browser.
# Get the real value from supabase.com → Settings → API (sb_secret_… or the service_role JWT).
SUPABASE_SECRET_KEY=sb_secret_or_service_role_jwt_here

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Mock→live seam. true = render from the bundled mock layer (no Supabase needed);
# false = read/write live Supabase rows (requires a signed-in session via GitHub OAuth).
# The deployed build runs live (false) for the Phase 7 demo.
NEXT_PUBLIC_USE_MOCK=false
# Brew Lab showcase tenant — the read-only empty-state shown before a user generates their own campaign.
NEXT_PUBLIC_DEMO_ACCOUNT_ID=00000000-0000-0000-0000-00000b1e51ab

# ===== Phase 8 e2e (Playwright) — TEST-ONLY, never set in Vercel/prod =====
# E2E_BYPASS_AUTH=1 makes middleware.ts skip the /login redirect so headless tests can
# reach gated routes. The mock project's webServer sets this automatically; do NOT add it
# to a deployed environment (it would disable the auth gate for all pages).
# E2E_BYPASS_AUTH=1
#
# Live DB e2e (e2e/live-db.e2e.ts) is skipped unless E2E_LIVE=1 AND these are set:
#   DEPLOY_URL                          — target the deployed app (defaults to local server)
#   E2E_TEST_EMAIL / E2E_TEST_PASSWORD  — the test user global-setup signs in / provisions
#   SUPABASE_SECRET_KEY                 — service-role key for DB-state assertions (above)
#   VERCEL_AUTOMATION_BYPASS_SECRET     — only if DEPLOY_URL has Vercel deployment protection
# E2E_LIVE=1
# DEPLOY_URL=https://offload-sable.vercel.app
# E2E_TEST_EMAIL=e2e@offload.test
# E2E_TEST_PASSWORD=...
# VERCEL_AUTOMATION_BYPASS_SECRET=...

# PostHog (public — Offload's OWN product funnel). OPTIONAL: analytics is a guarded no-op when unset.
# Project 363064. Get the key from the PostHog project settings.
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Canva Connect API — developers.canva.com/apps → New integration
# Scopes needed: design:content:write design:content:read design:meta:read asset:read
# Auth type: Authorization Code + PKCE (per-user OAuth)
CANVA_CLIENT_ID=...
CANVA_CLIENT_SECRET=...
# Full URL to your deployed callback endpoint — must match what's registered in Canva developer portal
# e.g. https://your-app.vercel.app/api/canva-callback
CANVA_REDIRECT_URI=...
